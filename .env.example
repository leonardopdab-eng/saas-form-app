# Optional. If omitted, the app still works and will send only the raw form answers by email.
OPENAI_API_KEY=

# Required for email delivery
RESEND_API_KEY=

# Required. Must be a verified sender on your Resend account.
RESEND_FROM_EMAIL=Acme Forms <forms@yourdomain.com>

# Required. Where the form result will be sent.
NOTIFICATION_EMAIL=you@example.com

# Optional. If set, browser-origin submissions must match this exact origin.
ALLOWED_ORIGIN=https://yourdomain.com

# Optional hardening controls
OPENAI_TIMEOUT_MS=8000
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=5
